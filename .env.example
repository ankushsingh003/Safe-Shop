# --------------------------------------------------------------------------
# 🛒 REAL-TIME E-COMMERCE PIPELINE: MASTER CONFIGURATION
# --------------------------------------------------------------------------

# --- 🟢 SYSTEM SECURITY (LAYER 6) ---
# This is the master key for your Intelligence API. 
# Keep it secret. Keep it safe.
API_KEY=your-super-secret-production-key

# --- 🔵 MESSAGE BROKER (KAFKA) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_ORDERS=order_events
KAFKA_TOPIC_FRAUD_ALERTS=fraud_alerts

# --- 🔴 INTELLIGENCE API (LAYERS 1-9) ---
ML_API_URL=http://localhost:8000
ML_API_KEY=your-super-secret-production-key

# --- 🟣 DATA WAREHOUSE (POSTGRESQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_orders
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce_orders
POSTGRES_PORT=5432

# --- 🟠 REAL-TIME FEATURE STORE (REDIS L3) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 🛡️ OPS ALERTING (LAYER 8) ---
# Create a Slack or Discord Incoming Webhook URL
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# --- 📈 MONITORING (GRAFANA L5) ---
KAFKA_UI_PORT=8080
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# --- ☁️ CLOUD CONFIG (OPTIONAL) ---
# Only needed if using S3/Databricks/AWS
AWS_ACCESS_KEY_ID=your-aws-id
AWS_SECRET_ACCESS_KEY=your-aws-secret
S3_BUCKET_NAME=your-fraud-raw-data-bucket
